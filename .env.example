GEMINI_API_KEY=your-gemini-api-key-here
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
DATABASE_URL=sqlite+aiosqlite:///./data/smartfill.db
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs

# Phase 3: File Watcher & Auto-Indexing
# Comma-separated directories to monitor for auto-indexing
# Example: WATCH_DIRS=~/Documents/papers,~/Research/projects
WATCH_DIRS=
WATCH_INTERVAL=5
AUTO_INDEX_COLLECTION=auto_indexed
SUPPORTED_EXTENSIONS=.docx,.pdf,.txt,.md

# Phase 4: Chat
CHAT_CONTEXT_ROUNDS=5

# Phase 6.1: Authentication
AUTH_ENABLED=True
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
